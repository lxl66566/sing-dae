node {
    my-node: 'hy2://change-me@server.example.com:65533/?sni=server.example.com#my-node'
    my-node2: 'hy2://change-me@server.example.com:65533/?sni=server.example.com#my-node2'
}

group {
    proxy {
        filter: name(my-node, my-node2)
        policy: min_moving_avg
    }
    direct {
        filter: name(my-node, my-node2)
        policy: min_moving_avg
    }
    test {
        filter: name(my-node, my-node2)
        policy: min_moving_avg
    }
}

routing {
    dip(geoip:private) -> direct
    domain(geosite:cn) -> test
    domain(geosite:google) -> proxy
    fallback: proxy
}
